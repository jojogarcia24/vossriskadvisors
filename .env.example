# ============================================================
# Voss Risk Advisors — environment variable checklist
# Copy this file to `.env` for local `netlify dev`, and set the
# same variables in Netlify (Site settings > Environment variables).
# NEVER commit the real `.env` — only this example belongs in git.
# ============================================================

# ---------- Supabase (database) ----------
# Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key — SECRET, server-side only (used by Netlify functions).
# Never expose this in index.html or any client code.
SUPABASE_SERVICE_ROLE=your-service-role-key
# anon (public) key — safe to expose client-side.
# Also paste this (with SUPABASE_URL) into the two globals in public/index.html.
SUPABASE_ANON_KEY=your-anon-public-key

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=your-resend-api-key
# Must be an address on your VERIFIED domain, e.g. quotes@vossriskadvisors.com
FROM_EMAIL=quotes@vossriskadvisors.com
# Where new-lead alerts are sent, e.g. info@vossriskadvisors.com
AGENCY_EMAIL=info@vossriskadvisors.com

# ---------- Anthropic (weekly blog generator) ----------
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional — defaults to a current Sonnet model in weekly-post.js
ANTHROPIC_MODEL=claude-sonnet-4-5
# Publishing control for the weekly AI post:
#   draft  -> saved as a draft for you to approve (recommended to start)
#   auto   -> publishes immediately (hands-off)
REVIEW_MODE=draft

# ---------- Carrier Appointments admin portal ----------
# Password to open /admin (the carrier appointment tracker). Pick a strong one.
ADMIN_PASSWORD=change-me-to-something-strong
# (ANTHROPIC_API_KEY above is reused for the "review a bulletin with Claude" tool.)

# ---------- Two-way Google Sheets sync (OPTIONAL) ----------
# Leave both blank to keep Google sync OFF — the admin portal and CSV export
# still work fully. To turn on live two-way sync, follow google/README.md:
#   1. GOOGLE_SHEET_WEBAPP_URL = the /exec URL of the Apps Script Web App bound
#      to your carrier Google Sheet (Voss -> Google pushes go here).
#   2. CARRIER_SYNC_SECRET = a shared secret string. Put the SAME value in the
#      Apps Script (SECRET) so Google -> Voss edits are authenticated.
GOOGLE_SHEET_WEBAPP_URL=
CARRIER_SYNC_SECRET=
